<Window x:Class="AutoHitCounter.Views.Windows.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AutoHitCounter.Views.Controls"
        Style="{StaticResource DefaultWindowStyle}"
        WindowStyle="None"
        AllowsTransparency="True"
        Title="Help" Height="420" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <controls:TitleBar Grid.Row="0" Title="Help Center" />

        <!-- Tab Headers -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,10,10,0">
                <StackPanel.Resources>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Margin" Value="0,0,4,0" />
                        <Setter Property="Padding" Value="10,4" />
                    </Style>
                </StackPanel.Resources>
                <Button x:Name="TabOverview" Content="Overview" Click="Tab_Click" Tag="0" />
                <Button x:Name="TabSplits" Content="Splits" Click="Tab_Click" Tag="1" />
                <Button x:Name="TabHotkeys" Content="Hotkeys" Click="Tab_Click" Tag="2" />
                <Button x:Name="TabProfileEditor" Content="Profile Editor" Click="Tab_Click" Tag="3" Margin="0,0,115,0" />
                <Button Content="A-" FontSize="11" Click="FontDecrease_Click" HorizontalAlignment="Right" />
                <Button Content="A+" FontSize="11" Click="FontIncrease_Click" HorizontalAlignment="Right" />
            </StackPanel>

            <!-- Pages -->
            <Border Grid.Row="1" Margin="10" BorderBrush="#333" BorderThickness="1" Padding="14">
                <!-- Overview -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <StackPanel x:Name="PageOverview">
                            <TextBlock Text="Overview" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" LineHeight="22">
                                Welcome to the Auto Hit Counter Help Center!
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" Margin="0,10,0,0" LineHeight="22">
                                Auto Hit Counter is a tool which tracks boss hits in all From Software Titles that are available on PC
                                (Dark Souls Remastered,Dark Souls 2,Dark Souls 3, Sekiro and Elden Ring).
                                This tool both increment hits and advance splits once a boss is defeated automatically.
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" Margin="0,10,0,0" LineHeight="22">
                                In the next panels you will get familiar with the capabilities of the tool and how you can set things up for your desired game. Good luck running, and don't get hit!
                            </TextBlock>
                        </StackPanel>


                        <!-- Splits -->
                        <StackPanel x:Name="PageSplits" Visibility="Collapsed">
                            <TextBlock Text="Splits" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10" />

                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" Margin="0,10,0,0" LineHeight="22">
                                Welcome to the Splits section! This is the main view and what you'll see when you first open the tool. Right under the Splits tab you can see a dropdown menu called Game.
                                Here is where you choose what game the tool should track hits for. Depending on the game certain features will unlock for both the settings tab and the profile editor settings.
                                Make sure to click the "Track" Button to let the tool know what you want to attach it to, give it a quick try here! 
                            </TextBlock>

                            <!-- Example Track -->
                            <StackPanel HorizontalAlignment="Left" Margin="0,0,4,0">
                                <TextBlock Text="GAME" FontFamily="{StaticResource AppFont}" FontSize="10"
                                           Foreground="#666666" Margin="2,0,0,2" />
                                <DockPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="Track"
                                            Height="22"
                                            Margin="4,0,0,0"
                                            Click="TrackExample_Click"/>
                                    <ComboBox x:Name="ExampleGame" Width="150" SelectedIndex="0">
                                        <ComboBoxItem Content="Dark Souls Remastered" />
                                        <ComboBoxItem Content="Dark Souls 2" />
                                        <ComboBoxItem Content="Dark Souls 3" />
                                        <ComboBoxItem Content="Sekiro" />
                                        <ComboBoxItem Content="Elden Ring" />
                                        </ComboBox>
                                </DockPanel>
                                <TextBlock x:Name="TrackingText" Text="Currently Tracking: "
                                           FontSize="9" Foreground="#555555" Margin="2,1,0,0" />
                            </StackPanel>
                            
                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" Margin="0,10,0,0" LineHeight="22">
                                Next to that from left to right are the Available Profiles Dropdown Menu, the Edit Profiles button and the Splits Lock button. But we will tackle the first two later on.
                                The Splits Lock button works as follows: When unlocked, the splits can be freely moved around and reordered. Double clicking any split will also open up a Split Rename box.
                                When locked however, the splits cannot be moved and double click goes from a renaming tool to a splitting tool.
                            </TextBlock>
                            
                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" Margin="0,10,0,0" LineHeight="22">
                                Below those two are the actual splits, you can double click the attempts count to edit it to whatever number you want or click the rewind button to reset it back to 0.
                                The splits section also has a context menu where you can easily access multiple features or rename splits even when they're locked. Just right click any split and check them out :)
                            </TextBlock>
                            
                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" Margin="0,10,0,0" LineHeight="22">
                                At the very bottom you will see the Total hits and the various buttons to navigate through splits, adjust the hit counter values, reset the attempt or clear all PBs. to the bottom right you can also see the In-Game Time.
                            </TextBlock>
                            
                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" Margin="0,10,0,0" LineHeight="22">
                                Once you finish a run, the bottom section will change to mark it as complete and you will get a prompt to mark that run as the new pb or to reset the splits.
                            </TextBlock>
                        </StackPanel>


                        <!-- Hotkeys -->
                        <StackPanel x:Name="PageHotkeys" Visibility="Collapsed">
                            <TextBlock Text="Hotkeys" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" LineHeight="22">
                                
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" Margin="0,10,0,0" LineHeight="22">
                                
                                <Run Foreground="White">Next Split, Previous Split, Increment Hit, Decrement Hit,</Run>
                                and
                                <Run Foreground="White">Reset.</Run>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" Margin="0,10,0,0" LineHeight="22">
                                
                            </TextBlock>
                        </StackPanel>

                        <!-- Profile Editor -->
                        <StackPanel x:Name="PageProfileEditor" Visibility="Collapsed">
                            <TextBlock Text="Profile Editor" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" LineHeight="22">
                                
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#CCC" Margin="0,10,0,0" LineHeight="22">
                                
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Prev / Next -->
        <Grid Grid.Row="2" Margin="10,0,10,10">
            <Button Content="← Prev" HorizontalAlignment="Left" Width="70" Height="24"
                    Click="Prev_Click" />
            <TextBlock x:Name="PageIndicator" Text="1 / 4"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#666" FontSize="11" />
            <Button Content="Next →" HorizontalAlignment="Right" Width="70" Height="24"
                    Click="Next_Click" />
        </Grid>
    </Grid>
</Window>